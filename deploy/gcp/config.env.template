# ============================================
# AgentShield GCP Deployment — Configuration
# ============================================
# Copy this file to config.env and fill in your values:
#   cp config.env.template config.env

# GCP Project
GCP_PROJECT_ID=agentshield-poc
GCP_REGION=us-central1

# Cloud SQL
DB_INSTANCE_NAME=agentshield-db
DB_NAME=agentshield
DB_USER=agentshield
# Leave empty to auto-generate during setup
DB_PASSWORD=

# Cloud Run — Backend
BACKEND_SERVICE_NAME=agentshield-api
BACKEND_MIN_INSTANCES=1
BACKEND_MAX_INSTANCES=4
BACKEND_CPU=1
BACKEND_MEMORY=1Gi

# Dashboard
DASHBOARD_PROJECT_ID=agentshield-poc
# Set after Step 4 completes (auto-detected)
BACKEND_URL=

# Admin credentials (used for seeding)
ADMIN_EMAIL=admin@agentshield.local
ADMIN_PASSWORD=admin123

# Memorystore Redis
REDIS_INSTANCE_NAME=agentshield-redis
REDIS_SIZE_GB=1

# VPC Connector
VPC_CONNECTOR_NAME=agentshield-vpc
VPC_CONNECTOR_RANGE=10.8.0.0/28
