# ============================================
# AgentShield Configuration
# ============================================

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agentshield
DB_USER=agentshield
DB_PASSWORD=agentshield_secret
DB_SSL=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Admin
ADMIN_EMAIL=admin@agentshield.local
ADMIN_PASSWORD=admin123

# Agent Health Check
HEALTH_CHECK_INTERVAL_MS=30000
HEALTH_CHECK_TIMEOUT_MS=5000
HEALTH_CHECK_UNHEALTHY_THRESHOLD=3

# Compliance
COMPLIANCE_ENCRYPTION_KEY=32-byte-encryption-key-change-me!
COMPLIANCE_DEFAULT_RETENTION_DAYS=2190

# Cost Tracking
COST_SYNC_INTERVAL_MS=60000

# ============================================
# OpenTelemetry (Observability)
# ============================================
# OTLP endpoint — set to your collector (Jaeger, Grafana Tempo, Datadog, etc.)
# Leave empty for console exporter in development
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=agentshield
# Sampling: 1.0 = 100%, 0.1 = 10%
# OTEL_TRACES_SAMPLER_ARG=1.0
# Metric export interval in ms
# OTEL_METRICS_EXPORT_INTERVAL=30000
# Set to 'debug' for verbose OTel SDK logging
# OTEL_LOG_LEVEL=info

